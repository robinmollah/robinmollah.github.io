:root
  --paper-base: #efe3d2
  --paper-soft: #f7efe2
  --paper-panel: rgba(251, 244, 235, 0.88)
  --paper-panel-strong: #fbf4ea
  --paper-tint: #ecd9c4
  --ink-strong: #2f241d
  --ink-body: #43372f
  --ink-muted: #7a685c
  --line-soft: rgba(126, 95, 71, 0.18)
  --line-strong: rgba(161, 119, 88, 0.34)
  --accent: #a15d3a
  --accent-soft: #c68058
  --shadow-soft: 0 16px 38px rgba(88, 60, 37, 0.1)
  --shadow-raised: 0 24px 54px rgba(80, 53, 33, 0.14)
  --radius-s: 12px
  --radius-m: 24px
  --radius-l: 36px
  --radius-pill: 999px
  --font-display: "Cormorant Garamond", "Iowan Old Style", "Times New Roman", serif
  --font-body: "Manrope", "Segoe UI", sans-serif

html, body
  background: linear-gradient(180deg, #f8f0e4 0%, var(--paper-base) 40%, #e6d5c2 100%)

body
  color: var(--ink-body)
  font-family: var(--font-body)
  background-attachment: fixed
  position: relative

body:before
  content: ""
  position: fixed
  inset: 0
  pointer-events: none
  background: radial-gradient(circle at 12% 18%, rgba(255, 255, 255, 0.34), transparent 18%), radial-gradient(circle at 88% 10%, rgba(185, 122, 80, 0.08), transparent 16%), linear-gradient(rgba(132, 96, 71, 0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(132, 96, 71, 0.015) 1px, transparent 1px)
  background-size: auto, auto, 10px 10px, 10px 10px
  mix-blend-mode: multiply
  opacity: 0.85
  z-index: -1

::selection
  background: rgba(176, 119, 79, 0.22)
  color: var(--ink-strong)

.use-motion .post-block,
.use-motion .pagination,
.use-motion .comments
  visibility: visible

.headband
  height: 8px
  background: linear-gradient(90deg, #815239, #b5774f 48%, #8d5f46)

.header
  background: transparent

.site-brand-container
  background: linear-gradient(180deg, rgba(73, 52, 38, 0.86), rgba(103, 73, 53, 0.72))
  border: 1px solid rgba(255, 239, 225, 0.16)
  border-radius: var(--radius-l)
  box-shadow: 0 20px 50px rgba(53, 35, 24, 0.16)
  margin: 0 auto 22px
  max-width: unquote('calc(100% - 28px)')
  position: relative
  overflow: hidden

.site-brand-container:before
  content: ""
  position: absolute
  inset: 0
  background: radial-gradient(circle at top right, rgba(255, 240, 223, 0.16), transparent 26%), linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 30%)
  pointer-events: none

.site-meta
  padding: 52px 24px 30px
  text-align: left

.brand
  border-bottom: 0

.logo-line
  background: rgba(247, 232, 218, 0.38)

.site-title
  font-family: var(--font-display)
  font-size: clamp(2.6rem, 4.8vw, 4.4rem)
  font-weight: 600
  letter-spacing: 0.03em
  color: #fff7ef
  text-shadow: 0 2px 18px rgba(27, 17, 12, 0.25)

.site-subtitle
  margin-top: 14px
  font-size: 0.82rem
  font-weight: 700
  letter-spacing: 0.16em
  text-transform: uppercase
  color: rgba(255, 245, 234, 0.84)

.site-nav
  background: transparent

.menu
  display: flex
  justify-content: center
  flex-wrap: wrap
  gap: 10px
  padding: 0 16px 26px

.menu-item a
  background: rgba(251, 241, 229, 0.9)
  border: 1px solid rgba(112, 76, 52, 0.18)
  border-radius: var(--radius-pill)
  color: #3a2b22
  font-size: 0.76rem
  font-weight: 700
  letter-spacing: 0.14em
  text-transform: uppercase
  padding: 11px 16px
  box-shadow: 0 10px 24px rgba(39, 26, 18, 0.12)
  transition: transform .22s ease, background-color .22s ease, border-color .22s ease, color .22s ease, box-shadow .22s ease

.menu-item a:visited
  color: #3a2b22

.menu-item a i
  color: #8a5131

.menu-item a:hover,
.menu-item-active a
  background: #a15d3a
  border-color: #a15d3a
  color: #fff8f1
  box-shadow: 0 14px 28px rgba(61, 40, 26, 0.18)
  transform: translateY(-1px)

.menu-item a:hover i,
.menu-item-active a i
  color: #fff1e4

.post-toc .nav .active > a,
.post-toc .nav .active > a:hover,
.post-toc .nav .active-current > a,
.post-toc .nav .active-current > a:hover
  color: var(--link-color)
  border-bottom-color: rgba(0, 85, 125, 1)
  font-weight: 600

.main-inner
  width: unquote('calc(100% - 36px)')
  max-width: 1120px
  padding-top: 18px

.sidebar a
  color: var(--link-color)
  border-bottom: 1px solid rgba(0, 0, 0, 0.1)

.sidebar
  margin-right: 24px

.sidebar a:hover 
  color: black
  font-weight: 500
  text-shadow: 1px 1px 2px #c39984ff

.sidebar-toc-active .sidebar-nav-toc, .sidebar-overview-active .sidebar-nav-overview
  color: var(--ink-body)
  font-weight: 600
  border-bottom-color: var(--accent)

.sidebar-toc-active .sidebar-nav-toc:hover, .sidebar-overview-active .sidebar-nav-overview:hover
  color: var(--accent)
  font-weight: 500


.sidebar-nav li:hover 
  color: var(--ink-body)
  

.sidebar-inner,
.sidebar-nav,
.sidebar-panel,
.site-overview,
.post-toc
  background: transparent

.sidebar-inner
  background: linear-gradient(180deg, rgba(248, 240, 230, 0.92), rgba(239, 225, 207, 0.9))
  border: 1px solid var(--line-soft)
  border-radius: var(--radius-m)
  box-shadow: var(--shadow-soft), inset 0 1px 0 rgba(255, 255, 255, 0.45)
  margin-top: 1em
  padding: 12px
  overflow: hidden

.post-body p, .post-body li
  max-width: 100% !important

.sidebar-nav
  border-bottom: 1px solid var(--line-soft)
  padding-bottom: 10px

.sidebar-nav li
  font-size: 0.72rem
  font-weight: 700
  letter-spacing: 0.12em
  text-transform: uppercase
  color: var(--ink-muted)

.sidebar-nav .sidebar-nav-active
  color: var(--accent)
  border-bottom-color: var(--accent)

.site-author-name,
.site-state-item-count
  font-family: var(--font-display)
  color: var(--ink-strong)

.site-author-name
  font-size: 1.8rem
  font-weight: 600

.site-state-item
  border-left-color: var(--line-soft)

.site-state-item-name
  color: var(--ink-muted)
  text-transform: uppercase
  letter-spacing: 0.12em
  font-size: 0.68rem

.post-block,
.pagination,
.comments,
.post-navigation
  background: linear-gradient(180deg, rgba(255, 251, 245, 0.94), rgba(247, 238, 226, 0.9))
  border: 1px solid var(--line-soft)
  border-radius: var(--radius-m)
  box-shadow: var(--shadow-soft), inset 0 1px 0 rgba(255, 255, 255, 0.4)

.post-block
  overflow: hidden
  transition: transform .24s ease, box-shadow .24s ease, border-color .24s ease

.post-block:hover
  transform: translateY(-4px)
  box-shadow: var(--shadow-raised), inset 0 1px 0 rgba(255, 255, 255, 0.4)
  border-color: var(--line-strong)

.page .post-header,
.post-header
  padding: 34px 40px 10px
  position: relative

.page .post-header:after,
.post-header:after
  content: ""
  display: block
  width: 88px
  height: 1px
  background: linear-gradient(90deg, var(--accent), rgba(161, 93, 58, 0))
  margin-top: 18px

.post-body
  padding: 0 40px 38px
  color: var(--ink-body)
  font-size: 1rem
  line-height: 1.85

.post-title,
.post-title-link
  font-family: var(--font-display)
  font-size: clamp(2.4rem, 3.6vw, 3.4rem)
  font-weight: 600
  line-height: 0.98
  letter-spacing: 0.01em
  color: var(--ink-strong)

.post-meta,
.post-description
  color: var(--ink-muted)

.post-body p,
.post-body li
  max-width: 72ch

.post-body h1,
.post-body h2,
.post-body h3,
.post-body h4,
.post-body h5,
.post-body h6
  font-family: var(--font-display)
  color: var(--ink-strong)
  font-weight: 600
  letter-spacing: 0.01em
  margin-top: 1.4em
  margin-bottom: 0.45em

.post-body h2
  font-size: 2.2rem

.post-body h3
  font-size: 1.7rem

.post-body h4
  font-size: 1.3rem

.post-body a
  color: var(--accent)
  border-bottom: 1px solid rgba(161, 93, 58, 0.24)
  font-weight: 600

.post-body a:hover
  color: var(--ink-strong)
  border-bottom-color: var(--accent)

.post-body table
  width: 100%
  border-collapse: collapse
  margin: 1.5rem 0
  background: rgba(248, 239, 228, 0.82)
  border: 1px solid var(--line-soft)
  border-radius: 18px
  overflow: hidden

.post-body th,
.post-body td
  padding: 0.95rem 1rem
  border-bottom: 1px solid rgba(126, 95, 71, 0.14)
  color: var(--ink-body)

.post-body th
  background: rgba(226, 202, 178, 0.42)
  color: var(--ink-strong)
  font-weight: 700
  text-align: left

.post-body tr:last-child td
  border-bottom: 0

.post-body table a
  color: #7f3f1f
  border-bottom-color: rgba(127, 63, 31, 0.3)

.post-body table a:hover
  color: #4a2716
  border-bottom-color: rgba(74, 39, 22, 0.48)

.post-body .contact-card,
.post-body .contact-card:link,
.post-body .contact-card:visited
  color: #342820 !important
  border-bottom: none !important

.post-body .contact-card:hover,
.post-body .contact-card:focus
  color: #2a1f18 !important

.post-body .contact-card .contact-label
  color: #2f241d !important

.post-body .contact-card .contact-value
  color: #6f4a32 !important
  font-weight: 600

.post-body hr
  border-color: transparent
  border-top: 1px solid var(--line-soft)

.post-body blockquote
  background: rgba(236, 217, 196, 0.34)
  border-left: 2px solid rgba(161, 93, 58, 0.4)
  border-radius: 0 var(--radius-s) var(--radius-s) 0
  color: #59453a
  margin: 1.5rem 0
  padding: 1rem 1.2rem

.post-body img
  border-radius: 18px
  box-shadow: 0 12px 28px rgba(86, 58, 37, 0.1)

.btn,
button,
summary.btn,
.post-button .btn
  background: linear-gradient(180deg, #fbf1e3, #eed9c2)
  border: 1px solid rgba(191, 150, 118, 0.52)
  border-radius: var(--radius-pill)
  color: var(--ink-strong)
  box-shadow: 0 10px 22px rgba(104, 72, 49, 0.08)
  font-size: 0.78rem
  font-weight: 700
  letter-spacing: 0.14em
  text-transform: uppercase
  padding: 10px 18px
  transition: transform .22s ease, box-shadow .22s ease, background-color .22s ease

.btn:hover,
button:hover,
summary.btn:hover,
.post-button .btn:hover
  background: var(--accent)
  color: #fff8f1
  border-color: var(--accent)
  transform: translateY(-1px)

.pagination
  margin-top: 32px
  padding: 12px

.page-number,
.extend
  border-radius: var(--radius-pill)
  color: var(--ink-body)

.page-number.current
  background: rgba(161, 93, 58, 0.12)
  color: var(--accent)

.post-tags a,
.tag-cloud a,
.sidebar .links-of-blogroll-item a
  display: inline-block
  margin: 0 8px 8px 0
  padding: 0.38rem 0.78rem
  border-radius: var(--radius-pill)
  background: rgba(227, 205, 182, 0.36)
  border: 1px solid rgba(191, 150, 118, 0.28)
  color: var(--ink-body)

.post-eof
  background: var(--line-soft)

.footer
  background: linear-gradient(180deg, rgba(52, 38, 30, 0.96), rgba(37, 27, 21, 0.98))
  border-top: 1px solid rgba(146, 110, 83, 0.32)

.footer-inner,
.copyright,
.powered-by,
.theme-info
  color: rgba(236, 216, 198, 0.82)

.footer a
  color: #f0c8a8

.back-to-top
  background: rgba(83, 57, 40, 0.84)

@media (max-width: 991px)
  .main-inner
    width: unquote('calc(100% - 24px)')

  .sidebar
    margin-right: 0

  .site-brand-container
    max-width: unquote('calc(100% - 20px)')

  .page .post-header,
  .post-header
    padding: 28px 24px 8px

  .post-body
    padding: 0 24px 28px

@media (max-width: 767px)
  .site-meta
    padding: 40px 16px 24px

  .site-title
    font-size: 2.7rem

  .site-subtitle
    letter-spacing: 0.12em

  .menu
    justify-content: flex-start
    padding: 0 14px 20px

  .menu-item a
    font-size: 0.72rem
    padding: 10px 14px

  .main-inner
    width: unquote('calc(100% - 16px)')

  .post-block,
  .pagination,
  .comments,
  .post-navigation,
  .sidebar-inner
    border-radius: 20px
